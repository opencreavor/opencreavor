#!/usr/bin/env bash
set -euo pipefail

APP=creavor
REPO=opencreavor/opencreavor
INSTALL_DIR=$HOME/.opencreavor/bin

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
GREEN='\033[0;32m'
NC='\033[0m'

usage() {
cat <<EOF
Usage: curl -fsSL https://raw.githubusercontent.com/${REPO}/main/install | bash

Options:
-h, --help             Show this help message
-v, --version VERSION  Install a specific version (e.g., 0.1.0)
-b, --binary PATH      Install from local binaries instead of downloading
--no-modify-path       Don't modify shell config files (.zshrc, .bashrc, etc.)
--no-service           Don't install broker-server as a system service
--uninstall            Uninstall opencreavor and remove the service

Examples:
  curl -fsSL https://raw.githubusercontent.com/${REPO}/main/install | bash
  curl -fsSL https://raw.githubusercontent.com/${REPO}/main/install | bash -s -- --version 0.1.0
  ./install --binary /path/to/creavor
  ./install --uninstall
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
no_service=false
uninstall=false
binary_dir=""

while [[ $# -gt 0 ]]; do
case "$1" in
-h|--help)
  usage
  exit 0
  ;;
-v|--version)
  if [[ -n "${2:-}" ]]; then
    requested_version="$2"
    shift 2
  else
    echo -e "${RED}Error: --version requires a version argument${NC}" >&2
    exit 1
  fi
  ;;
-b|--binary)
  if [[ -n "${2:-}" ]]; then
    binary_dir="$2"
    shift 2
  else
    echo -e "${RED}Error: --binary requires a directory argument${NC}" >&2
    exit 1
  fi
  ;;
--no-modify-path)
  no_modify_path=true
  shift
  ;;
--no-service)
  no_service=true
  shift
  ;;
--uninstall)
  uninstall=true
  shift
  ;;
*)
  echo -e "${ORANGE}Warning: Unknown option '$1'${NC}" >&2
  shift
  ;;
esac
done

# ---------------------------------------------------------------------------
# Uninstall
# ---------------------------------------------------------------------------

uninstall_opencreavor() {
  print_message info "\n${MUTED}Uninstalling opencreavor...${NC}"

  # Stop and remove service
  remove_service

  # Remove binaries
  if [[ -d "$INSTALL_DIR" ]]; then
    rm -f "${INSTALL_DIR}/creavor" "${INSTALL_DIR}/broker-server"
    if [[ -z "$(ls -A "$INSTALL_DIR" 2>/dev/null)" ]]; then
      rmdir "$INSTALL_DIR"
      print_message success "Removed ${INSTALL_DIR}"
    else
      print_message info "${MUTED}Kept ${INSTALL_DIR} (not empty)${NC}"
    fi
  fi

  # Remove config (ask user first? just leave it)
  print_message info "${MUTED}Config preserved at ~/.opencreavor/${NC}"

  print_message success "\nUninstalled opencreavor."
  print_message info "${MUTED}Remove PATH entries from your shell config manually if needed.${NC}"
  exit 0
}

print_message() {
  local level=$1
  local message=$2
  local color=""
  case $level in
  info) color="${NC}" ;;
  warning) color="${ORANGE}" ;;
  error) color="${RED}" ;;
  success) color="${GREEN}" ;;
  esac
  echo -e "${color}${message}${NC}"
}

# ---------------------------------------------------------------------------
# OS / Arch detection
# ---------------------------------------------------------------------------

detect_platform() {
  local raw_os=$(uname -s)
  local os=$(echo "$raw_os" | tr '[:upper:]' '[:lower:]')

  case "$raw_os" in
  Darwin*) os="darwin" ;;
  Linux*) os="linux" ;;
  MINGW*|MSYS*|CYGWIN*) os="windows" ;;
  esac

  local arch=$(uname -m)
  if [[ "$arch" == "aarch64" ]]; then arch="arm64"; fi
  if [[ "$arch" == "x86_64" ]]; then arch="x64"; fi

  # Rosetta check on macOS
  if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
    local rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
    if [ "$rosetta_flag" = "1" ]; then arch="arm64"; fi
  fi

  local combo="$os-$arch"
  case "$combo" in
  linux-x64|linux-arm64|darwin-x64|darwin-arm64)
    echo "$combo"
    ;;
  *)
    echo -e "${RED}Unsupported OS/Arch: $os/$arch${NC}" >&2
    exit 1
    ;;
  esac
}

# ---------------------------------------------------------------------------
# Build from source via cargo
# ---------------------------------------------------------------------------

build_from_source() {
  if ! command -v cargo >/dev/null 2>&1; then
    print_message error "Error: 'cargo' is required but not installed."
    print_message info "Install Rust: https://rustup.rs"
    exit 1
  fi

  local version_flag=""
  if [[ -n "$requested_version" ]]; then
    version_flag="--tag v${requested_version}"
  fi

  print_message info "\n${MUTED}Building ${NC}${APP}${MUTED} from source...${NC}"

  local tmp_dir="${TMPDIR:-/tmp}/opencreavor_build_$$"
  mkdir -p "$tmp_dir"

  git clone ${version_flag} --depth 1 https://github.com/${REPO}.git "$tmp_dir/repo" 2>&1 | \
    while IFS= read -r line; do printf "\r${MUTED}%s${NC}" "$line"; done; echo

  cargo build --release --manifest-path "$tmp_dir/repo/Cargo.toml" 2>&1 | \
    while IFS= read -r line; do printf "\r${MUTED}%s${NC}" "$line"; done; echo

  mkdir -p "$INSTALL_DIR"
  cp "$tmp_dir/repo/target/release/creavor" "${INSTALL_DIR}/creavor"
  cp "$tmp_dir/repo/target/release/broker-server" "${INSTALL_DIR}/broker-server"
  chmod 755 "${INSTALL_DIR}/creavor" "${INSTALL_DIR}/broker-server"

  rm -rf "$tmp_dir"

  print_message success "Built and installed to ${INSTALL_DIR}"
}

# ---------------------------------------------------------------------------
# Download prebuilt binary from GitHub releases
# ---------------------------------------------------------------------------

download_and_install() {
  local platform=$(detect_platform)
  local archive_ext=".tar.gz"
  if [[ "$platform" == darwin-* ]]; then
    archive_ext=".zip"
  fi

  local filename="${APP}-${platform}${archive_ext}"
  local url
  local specific_version

  if [[ -z "$requested_version" ]]; then
    url="https://github.com/${REPO}/releases/latest/download/${filename}"
    specific_version=$(curl -s https://api.github.com/repos/${REPO}/releases/latest | \
      sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')
    if [[ -z "$specific_version" ]]; then
      print_message error "Failed to fetch latest version. Falling back to build from source."
      build_from_source
      return
    fi
  else
    requested_version="${requested_version#v}"
    url="https://github.com/${REPO}/releases/download/v${requested_version}/${filename}"
    specific_version="$requested_version"

    local http_status=$(curl -sI -o /dev/null -w "%{http_code}" \
      "https://github.com/${REPO}/releases/tag/v${requested_version}")
    if [ "$http_status" = "404" ]; then
      print_message warning "Release v${requested_version} not found. Falling back to build from source."
      build_from_source
      return
    fi
  fi

  print_message info "\n${MUTED}Installing ${NC}${APP}${MUTED} version: ${NC}${specific_version}"

  local tmp_dir="${TMPDIR:-/tmp}/opencreavor_install_$$"
  mkdir -p "$tmp_dir"

  print_message info "${MUTED}Downloading ${NC}${filename}..."
  curl -# -L -o "$tmp_dir/$filename" "$url"

  if [ "${platform%%-*}" = "linux" ]; then
    tar -xzf "$tmp_dir/$filename" -C "$tmp_dir"
  else
    unzip -q "$tmp_dir/$filename" -d "$tmp_dir"
  fi

  mkdir -p "$INSTALL_DIR"
  mv "$tmp_dir/creavor" "${INSTALL_DIR}/creavor" 2>/dev/null || true
  mv "$tmp_dir/broker-server" "${INSTALL_DIR}/broker-server" 2>/dev/null || true
  chmod 755 "${INSTALL_DIR}/creavor" "${INSTALL_DIR}/broker-server"

  rm -rf "$tmp_dir"

  print_message success "Installed to ${INSTALL_DIR}"
}

# ---------------------------------------------------------------------------
# Install from local binaries
# ---------------------------------------------------------------------------

install_from_binary() {
  if [[ ! -d "$binary_dir" ]]; then
    echo -e "${RED}Error: Directory not found at ${binary_dir}${NC}" >&2
    exit 1
  fi

  mkdir -p "$INSTALL_DIR"

  if [[ -f "$binary_dir/creavor" ]]; then
    cp "$binary_dir/creavor" "${INSTALL_DIR}/creavor"
    chmod 755 "${INSTALL_DIR}/creavor"
  else
    echo -e "${RED}Error: 'creavor' binary not found in ${binary_dir}${NC}" >&2
    exit 1
  fi

  if [[ -f "$binary_dir/broker-server" ]]; then
    cp "$binary_dir/broker-server" "${INSTALL_DIR}/broker-server"
    chmod 755 "${INSTALL_DIR}/broker-server"
  else
    print_message warning "broker-server not found in ${binary_dir}, skipping"
  fi

  print_message success "Installed from ${binary_dir}"
}

# ---------------------------------------------------------------------------
# Service management
# ---------------------------------------------------------------------------

detect_os() {
  local raw_os=$(uname -s)
  case "$raw_os" in
  Darwin*) echo "darwin" ;;
  Linux*) echo "linux" ;;
  *) echo "unknown" ;;
  esac
}

install_service() {
  if [[ "$no_service" == "true" ]]; then return; fi
  if [[ ! -f "${INSTALL_DIR}/broker-server" ]]; then
    print_message warning "broker-server not found, skipping service installation"
    return
  fi

  local os=$(detect_os)
  case "$os" in
  darwin) install_launchd_service ;;
  linux)  install_systemd_service ;;
  *)      print_message warning "Service auto-start not supported on $os" ;;
  esac
}

remove_service() {
  local os=$(detect_os)
  case "$os" in
  darwin) remove_launchd_service ;;
  linux)  remove_systemd_service ;;
  esac
}

# Stop the broker service without removing its config.
# Used before overwriting binaries during an upgrade.
stop_service_for_upgrade() {
  local os=$(detect_os)
  case "$os" in
  darwin) stop_launchd_service ;;
  linux)  stop_systemd_service ;;
  esac
}

# --- macOS launchd ---

install_launchd_service() {
  local plist_name="com.opencreavor.broker"
  local plist_dir="$HOME/Library/LaunchAgents"
  local plist_path="${plist_dir}/${plist_name}.plist"
  local log_dir="$HOME/.opencreavor/logs"
  local log_path="${log_dir}/broker-server.log"

  mkdir -p "$plist_dir" "$log_dir"

  # Stop existing service completely before writing new plist.
  # With KeepAlive=true, launchd may auto-restart after bootout,
  # so we must unload first, then wait for the process to exit.
  stop_launchd_service

  # Rotate log if it exceeds 10 MB (3 generations kept).
  if [[ -f "$log_path" ]] && [[ $(stat -f%z "$log_path" 2>/dev/null || echo 0) -gt 10485760 ]]; then
    for i in 2 1; do
      [[ -f "${log_path}.${i}" ]] && mv "${log_path}.${i}" "${log_path}.$((i+1))"
    done
    mv "$log_path" "${log_path}.1"
    print_message info "${MUTED}Rotated broker log (exceeded 10 MB)${NC}"
  fi

  cat > "$plist_path" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${plist_name}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${INSTALL_DIR}/broker-server</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${log_path}</string>
    <key>StandardErrorPath</key>
    <string>${log_path}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>RUST_LOG</key>
        <string>info</string>
    </dict>
</dict>
</plist>
PLIST

  launchctl bootstrap "gui/$(id -u)" "$plist_path" 2>/dev/null

  print_message success "broker-server installed as launchd service (auto-start on login)"
  print_message info "${MUTED}  Log: ${log_path}${NC}"
  print_message info "${MUTED}  Manage: launchctl kickstart -k gui/$(id -u)/${plist_name}${NC}"
}

remove_launchd_service() {
  local plist_name="com.opencreavor.broker"
  local plist_path="$HOME/Library/LaunchAgents/${plist_name}.plist"

  stop_launchd_service

  if [[ -f "$plist_path" ]]; then
    rm "$plist_path"
    print_message info "${MUTED}Removed ${plist_path}${NC}"
  fi
}

stop_launchd_service() {
  local plist_name="com.opencreavor.broker"
  local plist_path="$HOME/Library/LaunchAgents/${plist_name}.plist"

  if ! launchctl list "$plist_name" >/dev/null 2>&1; then
    return
  fi

  print_message info "${MUTED}Stopping broker service...${NC}"
  launchctl bootout "gui/$(id -u)/${plist_name}" 2>/dev/null || true

  # Wait for the process to actually exit (up to 5 seconds).
  # With KeepAlive=true, launchd may try to restart, so we also
  # temporarily disable the plist to prevent that.
  if [[ -f "$plist_path" ]]; then
    launchctl unload "$plist_path" 2>/dev/null || true
  fi

  local waited=0
  while launchctl list "$plist_name" >/dev/null 2>&1 && [[ $waited -lt 50 ]]; do
    sleep 0.1
    waited=$((waited + 1))
  done
}

# --- Linux systemd ---

install_systemd_service() {
  if ! command -v systemctl >/dev/null 2>&1; then
    print_message warning "systemctl not found, skipping service installation"
    return
  fi

  local service_dir="$HOME/.config/systemd/user"
  local service_path="${service_dir}/creavor-broker.service"
  local log_dir="$HOME/.opencreavor/logs"

  mkdir -p "$service_dir" "$log_dir"

  # Stop existing service before writing new unit file.
  stop_systemd_service

  # Rotate log if it exceeds 10 MB (3 generations kept).
  local log_file="${log_dir}/broker-server.log"
  if [[ -f "$log_file" ]] && [[ $(stat -c%s "$log_file" 2>/dev/null || echo 0) -gt 10485760 ]]; then
    for i in 2 1; do
      [[ -f "${log_file}.${i}" ]] && mv "${log_file}.${i}" "${log_file}.$((i+1))"
    done
    mv "$log_file" "${log_file}.1"
    print_message info "${MUTED}Rotated broker log (exceeded 10 MB)${NC}"
  fi

  cat > "$service_path" <<SERVICE
[Unit]
Description=OpenCreavor Broker Server
After=network.target

[Service]
Type=simple
ExecStart=${INSTALL_DIR}/broker-server
Restart=on-failure
RestartSec=5
Environment=RUST_LOG=info
StandardOutput=append:${log_dir}/broker-server.log
StandardError=append:${log_dir}/broker-server.log

[Install]
WantedBy=default.target
SERVICE

  systemctl --user daemon-reload
  systemctl --user enable --now creavor-broker.service 2>/dev/null

  print_message success "broker-server installed as systemd user service (auto-start on login)"
  print_message info "${MUTED}  Log: ${log_dir}/broker-server.log${NC}"
  print_message info "${MUTED}  Manage: systemctl --user start/stop/restart creavor-broker${NC}"
  print_message info "${MUTED}  Status: systemctl --user status creavor-broker${NC}"
}

remove_systemd_service() {
  if ! command -v systemctl >/dev/null 2>&1; then return; fi

  if systemctl --user is-active creavor-broker >/dev/null 2>&1; then
    systemctl --user stop creavor-broker 2>/dev/null || true
    print_message info "${MUTED}Stopped broker service${NC}"
  fi
  if systemctl --user is-enabled creavor-broker >/dev/null 2>&1; then
    systemctl --user disable creavor-broker 2>/dev/null || true
  fi

  local service_path="$HOME/.config/systemd/user/creavor-broker.service"
  if [[ -f "$service_path" ]]; then
    rm "$service_path"
    systemctl --user daemon-reload 2>/dev/null || true
    print_message info "${MUTED}Removed ${service_path}${NC}"
  fi
}

stop_systemd_service() {
  if ! command -v systemctl >/dev/null 2>&1; then return; fi

  if systemctl --user is-active creavor-broker >/dev/null 2>&1; then
    print_message info "${MUTED}Stopping broker service...${NC}"
    systemctl --user stop creavor-broker 2>/dev/null || true
  fi
}

add_to_path() {
  local config_file=$1
  local command=$2

  if grep -Fxq "$command" "$config_file"; then
    print_message info "${MUTED}Command already exists in ${NC}${config_file}${MUTED}, skipping.${NC}"
  elif [[ -w $config_file ]]; then
    echo -e "\n# opencreavor" >> "$config_file"
    echo "$command" >> "$config_file"
    print_message info "${MUTED}Added ${NC}${APP}${MUTED} to \$PATH in ${NC}${config_file}"
  else
    print_message warning "Manually add to ${config_file}:"
    print_message info "  ${command}"
  fi
}

configure_path() {
  if [[ "$no_modify_path" == "true" ]]; then return; fi
  if [[ ":$PATH:" == *":$INSTALL_DIR:"* ]]; then
    print_message info "${MUTED}${INSTALL_DIR} already in PATH${NC}"
    return
  fi

  local current_shell=$(basename "${SHELL:-}")
  local config_files=""

  case $current_shell in
  fish) config_files="$HOME/.config/fish/config.fish" ;;
  zsh)  config_files="${ZDOTDIR:-$HOME}/.zshrc ${ZDOTDIR:-$HOME}/.zshenv" ;;
  bash) config_files="$HOME/.bashrc $HOME/.bash_profile $HOME/.profile" ;;
  ash|sh) config_files="$HOME/.profile" ;;
  *)    config_files="$HOME/.bashrc $HOME/.bash_profile" ;;
  esac

  local config_file=""
  for file in $config_files; do
    if [[ -f $file ]]; then
      config_file=$file
      break
    fi
  done

  if [[ -z $config_file ]]; then
    print_message warning "No shell config found for ${current_shell}. Add to PATH manually:"
    print_message info "  export PATH=${INSTALL_DIR}:\$PATH"
    return
  fi

  case $current_shell in
  fish) add_to_path "$config_file" "fish_add_path ${INSTALL_DIR}" ;;
  *)    add_to_path "$config_file" "export PATH=${INSTALL_DIR}:\$PATH" ;;
  esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$uninstall" == "true" ]]; then
  uninstall_opencreavor
fi

mkdir -p "$INSTALL_DIR"

# Stop running service before overwriting binaries to avoid
# "Text file busy" errors on Linux and stale-process issues on macOS.
stop_service_for_upgrade

if [[ -n "$binary_dir" ]]; then
  install_from_binary
else
  download_and_install
fi

install_service
configure_path

# GitHub Actions support
if [[ -n "${GITHUB_ACTIONS-}" ]] && [[ "${GITHUB_ACTIONS}" == "true" ]]; then
  echo "$INSTALL_DIR" >> "$GITHUB_PATH"
  print_message info "Added ${INSTALL_DIR} to \$GITHUB_PATH"
fi

# Banner
echo ""
echo -e "${MUTED}  █▀▀▄ █▀▀█ █▀▀█ █▀▀▄ █${NC}  ${MUTED}▄▀▀▄ █▀▀█ █▀▀█ ▄▀▀▄ █░░█ █▀▀▄ █▀▀█${NC}"
echo -e "${MUTED}  █░░█ █░░█ █▀▀▀ █░░█ █${NC}  ${MUTED}█░░█ █▀▀▄ █▀▀▀ █▀▀█ ▀▄▄▀ █░░█ █▀▀▄${NC}"
echo -e "${MUTED}  ▀▀▀▀ ▀▀▀▀ ▀▀▀▀ ▀ ▀ ▀${NC}  ${MUTED}█▄▄█ █░░█ ▀▀▀▀ █░░█  ▀▀  ▀▀▀▀ █░░█${NC}"
echo ""
echo -e "${MUTED}Installed:${NC}"
echo -e "  ${GREEN}creavor${NC}        ${MUTED}CLI tool to launch AI runtimes through the broker${NC}"
echo -e "  ${GREEN}broker-server${NC}  ${MUTED}Local interception proxy for AI coding runtimes${NC}"
echo ""
echo -e "${MUTED}Quick start:${NC}"
echo -e "  ${MUTED}1.${NC} creavor run claude ${MUTED}# Launch Claude Code (broker auto-started as service)${NC}"
echo -e "  ${MUTED}2.${NC} creavor status ${MUTED}# Check broker health${NC}"
echo -e ""
echo -e "${MUTED}Service management:${NC}"
if [[ "$(detect_os)" == "darwin" ]]; then
echo -e "  ${MUTED}launchctl kickstart -k gui/\$(id -u)/com.opencreavor.broker${NC}  # restart"
echo -e "  ${MUTED}launchctl bootout gui/\$(id -u)/com.opencreavor.broker${NC}       # stop"
else
echo -e "  ${MUTED}systemctl --user restart creavor-broker${NC}  # restart"
echo -e "  ${MUTED}systemctl --user stop creavor-broker${NC}     # stop"
fi
echo ""
echo -e "${MUTED}Supported runtimes: claude, gemini, codex, opencode, openclaw, cline${NC}"
echo -e "${MUTED}Docs: https://github.com/${REPO}${NC}"
echo ""
